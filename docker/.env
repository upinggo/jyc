
# JYC Docker environment configuration
# Copy this file to .env and fill in the values.

# JYC data directory (contains config.toml, channel dirs, workspace)
JYC_DATA_DIR=/Users/D032459/Documents/work/projects/kingye/jyc-data

# OpenCode global config (API keys, providers, model settings)
OPENCODE_CONFIG=/Users/D032459/Documents/work/projects/kingye/jiny-m-channels/opencode.jsonc

# OpenCode data directory (sessions DB, logs, snapshots — persisted across restarts)
# Uses a Docker named volume by default. Set a host path to share with host:
OPENCODE_DATA_DIR=/Users/D032459/Documents/work/projects/kingye/jyc-data

# Skills directories (mounted read-only into the container)
# CLAUDE_SKILLS_DIR=/Users/D032459/.claude/skills
# AGENT_SKILLS_DIR=/Users/D032459/.agents/skills

# Project source mounts (for AI self-bootstrapping)
# Mount source dirs into specific thread workspaces in docker-compose.yml.
# Example: mount jyc source into a bootstrapping thread:
#   - /path/to/jyc:/opt/jyc/<channel>/workspace/<thread>/jyc
#
#
JYC_DIR=/Users/D032459/Documents/work/projects/kingye/jyc

NETWORKCALC_DIR=/Users/D032459/Documents/work/projects/climate-21/c21-networkcalculation-srv
